{
  "title": "DevOps Project — Monitoreo",
  "uid": "devops-project-v1",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-30m", "to": "now" },
  "timezone": "browser",
  "tags": ["devops", "docker", "yolo"],
  "panels": [

    {
      "id": 1,
      "title": "CPU por contenedor (%)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "color": { "mode": "palette-classic" }
        }
      },
      "targets": [
        {
          "expr": "rate(container_cpu_usage_seconds_total{name=~\"detector|chatbot|yolo-exporter\"}[1m]) * 100",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ]
    },

    {
      "id": 2,
      "title": "Memoria por contenedor (MB)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "decmbytes",
          "min": 0,
          "color": { "mode": "palette-classic" }
        }
      },
      "targets": [
        {
          "expr": "container_memory_usage_bytes{name=~\"detector|chatbot|yolo-exporter\"} / 1024 / 1024",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ]
    },

    {
      "id": 3,
      "title": "Red — Bytes recibidos (RX)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "color": { "mode": "palette-classic" }
        }
      },
      "targets": [
        {
          "expr": "rate(container_network_receive_bytes_total{name=~\"detector|chatbot\"}[1m])",
          "legendFormat": "{{name}} RX",
          "refId": "A"
        }
      ]
    },

    {
      "id": 4,
      "title": "Red — Bytes enviados (TX)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "color": { "mode": "palette-classic" }
        }
      },
      "targets": [
        {
          "expr": "rate(container_network_transmit_bytes_total{name=~\"detector|chatbot\"}[1m])",
          "legendFormat": "{{name}} TX",
          "refId": "A"
        }
      ]
    },

    {
      "id": 5,
      "title": "Detecciones YOLO — Total acumulado",
      "type": "stat",
      "gridPos": { "x": 0, "y": 16, "w": 6, "h": 5 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 200 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "yolo_detections_total",
          "legendFormat": "Detecciones totales",
          "refId": "A"
        }
      ]
    },

    {
      "id": 6,
      "title": "Detecciones YOLO — Por logo (últimos 5 min)",
      "type": "bargauge",
      "gridPos": { "x": 6, "y": 16, "w": 10, "h": 5 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "min": 0
        }
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient"
      },
      "targets": [
        {
          "expr": "increase(yolo_logo_detections_total[5m])",
          "legendFormat": "{{logo}}",
          "refId": "A"
        }
      ]
    },

    {
      "id": 7,
      "title": "Logos detectados ahora",
      "type": "stat",
      "gridPos": { "x": 16, "y": 16, "w": 8, "h": 5 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "yolo_logos_active",
          "legendFormat": "Logos en pantalla",
          "refId": "A"
        }
      ]
    },

    {
      "id": 8,
      "title": "CPU Host — Arch Linux (%)",
      "type": "gauge",
      "gridPos": { "x": 0, "y": 21, "w": 6, "h": 5 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 60 },
              { "color": "red", "value": 85 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\"}[1m])) * 100)",
          "legendFormat": "CPU %",
          "refId": "A"
        }
      ]
    },

    {
      "id": 9,
      "title": "RAM Host — Arch Linux (%)",
      "type": "gauge",
      "gridPos": { "x": 6, "y": 21, "w": 6, "h": 5 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "(1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)) * 100",
          "legendFormat": "RAM %",
          "refId": "A"
        }
      ]
    },

    {
      "id": 10,
      "title": "Tráfico de red — Host (Bps)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 21, "w": 12, "h": 5 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "color": { "mode": "palette-classic" }
        }
      },
      "targets": [
        {
          "expr": "rate(node_network_receive_bytes_total{device!~\"lo|veth.*|br-.*|docker.*\"}[1m])",
          "legendFormat": "RX {{device}}",
          "refId": "A"
        },
        {
          "expr": "rate(node_network_transmit_bytes_total{device!~\"lo|veth.*|br-.*|docker.*\"}[1m])",
          "legendFormat": "TX {{device}}",
          "refId": "B"
        }
      ]
    }

  ]
}
